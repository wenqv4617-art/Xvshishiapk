<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <meta name="theme-color" id="theme-color-meta" content="#f4f6fa">
  <title>叙事诗小手机</title>
  <link rel="manifest" href="manifest.json">
  <link rel="stylesheet" href="style.css">
  <link rel="stylesheet" href="app.css">
  <link rel="stylesheet" href="chat.css">
  <script src="https://unpkg.com/dexie@4.0.1/dist/dexie.js"></script>
</head>
<body>
  <div id="phone-container">
    <!-- 桌面网格 -->
    <main id="desktop">
      <div class="app-grid" id="desktop-grid">
        <!-- 由 JS 渲染桌面图标 -->
      </div>
    </main>

    <!-- 各类应用窗口 -->
    <div id="app-window-container">
      
      <!-- === 设置应用 === -->
      <div id="win-settings" class="app-window">
        <header class="win-header">
          <button class="btn-icon" id="btn-settings-back" onclick="handleSettingsBack()">
            <svg viewBox="0 0 24 24"><path fill="currentColor" d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
          </button>
          <h3 id="settings-title">系统设置</h3>
          <div style="width:40px;"></div>
        </header>
        <div class="win-body">
          <!-- 一级主菜单 -->
          <div id="settings-lv1">
            <div class="menu-item" onclick="openSettingsLv2('api')">
              <span>API 协议设置</span>
              <svg viewBox="0 0 24 24" class="chevron"><path fill="currentColor" d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/></svg>
            </div>
            <div class="menu-item" onclick="openSettingsLv2('data')">
              <span>本地数据管理</span>
              <svg viewBox="0 0 24 24" class="chevron"><path fill="currentColor" d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/></svg>
            </div>
          </div>
          <!-- 二级：API 设置 -->
          <div id="settings-lv2-api" class="settings-lv2-panel" style="display:none;">
            <div class="form-group">
              <label>配置预设</label>
              <div class="preset-row">
                <select id="api-presets-select"><option value="">-- 选择已有预设 --</option></select>
                <button id="btn-delete-preset" class="btn btn-danger-outline">删除</button>
              </div>
            </div>
            <div class="form-group">
              <label>预设名称</label>
              <input type="text" id="api-preset-name" placeholder="预设名称">
            </div>
            <div class="form-group">
              <label>选择协议</label>
              <select id="api-protocol">
                <option value="openai">OpenAI</option>
                <option value="openai-compatible">兼容 OpenAI</option>
                <option value="gemini">Gemini 官方</option>
                <option value="deepseek">DeepSeek 官方</option>
              </select>
            </div>
            <div class="form-group">
              <label>API 终结点 (URL)</label>
              <input type="text" id="api-url" placeholder="https://api.openai.com/v1">
            </div>
            <div class="form-group">
              <label>API Key</label>
              <input type="password" id="api-key" placeholder="API Key">
            </div>
            <div class="form-group">
              <label>模型选择</label>
              <div class="model-row">
                <select id="api-model-select"><option value="">请先拉取模型</option></select>
                <button id="btn-fetch-models" class="btn">拉取</button>
              </div>
            </div>
            <div class="form-group">
              <label>模型温度 (Temperature: <span id="temp-val">0.7</span>)</label>
              <input type="range" id="api-temp" min="0" max="2" step="0.1" value="0.7">
            </div>
            <div class="form-actions">
              <button id="btn-test-api" class="btn btn-outline">测试连接</button>
              <button id="btn-save-preset" class="btn">保存预设</button>
              <button id="btn-apply-global" class="btn btn-primary">应用到全局</button>
            </div>
          </div>
          <!-- 二级：数据管理 -->
          <div id="settings-lv2-data" class="settings-lv2-panel" style="display:none;">
            <div class="data-status-card">
              <h4>本地存储状态</h4>
              <p>总记录数: <span id="db-total-records">0</span></p>
              <p>所有资源空间: <span id="db-total-bytes">0 KB</span></p>
              <p>图片所占空间: <span id="db-image-bytes">0 KB</span></p>
            </div>
            <div class="data-actions">
              <button id="btn-export-data" class="btn" style="width:100%; margin-bottom:10px;">导出备份 (JSON)</button>
              <button id="btn-import-trigger" class="btn btn-outline" style="width:100%;">导入备份 (JSON)</button>
              <input type="file" id="file-import" accept=".json" style="display: none;">
            </div>
          </div>
        </div>
      </div>

      <!-- === 档案库应用 === -->
      <div id="win-archive" class="app-window">
        <header class="win-header">
          <button class="btn-icon" onclick="closeApp('archive')">
            <svg viewBox="0 0 24 24"><path fill="currentColor" d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
          </button>
          <h3 id="archive-title">档案库 - 角色</h3>
          <button class="btn-icon" id="btn-add-archive">
            <svg viewBox="0 0 24 24"><path fill="currentColor" d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
          </button>
        </header>
        <div class="win-body">
          <div id="archive-list-container" class="archive-main"></div>
          <!-- 档案表单弹层 -->
          <div id="archive-form-overlay" class="modal-overlay">
            <div class="modal">
              <header class="modal-header">
                <h4 id="form-title">添加新角色</h4>
                <button class="btn-icon" id="btn-close-form">
                  <svg viewBox="0 0 24 24"><path fill="currentColor" d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
                </button>
              </header>
              <form id="archive-form" onsubmit="return false;">
                <input type="hidden" id="archive-id">
                
                <!-- 上方中央预览与上传区 -->
                <div class="avatar-uploader-container">
                  <div id="avatar-dropzone" class="avatar-preview-circle">
                    <svg viewBox="0 0 24 24" id="placeholder-avatar"><path fill="currentColor" d="M9 16h6v-6h4l-7-7-7 7h4v6zm-4 2h14v2H5v-2z"/></svg>
                    <img id="avatar-preview-img" style="display:none;" />
                  </div>
                  <span class="upload-tip">点击、拖拽或粘贴截图导入头像</span>
                  <input type="file" id="archive-avatar-file" accept="image/*" style="display:none;">
                </div>
                <div class="form-group" id="form-avatar-url-group">
                  <label>或直接输入头像 URL</label>
                  <input type="text" id="archive-avatar-url" placeholder="https://example.com/avatar.png">
                </div>

                <div class="form-group" id="form-npc-parent-group" style="display: none;">
                  <label>归属角色/用户</label>
                  <select id="archive-parent-id"></select>
                </div>
                <div id="form-relation-fields" style="display: none;">
                  <div class="form-group"><label>源端角色/用户 (From)</label><select id="relation-from"></select></div>
                  <div class="form-group"><label>终端角色/用户 (To)</label><select id="relation-to"></select></div>
                  <div class="form-group"><label>关系描述</label><input type="text" id="relation-desc" placeholder="关系名称 (例如: 挚友、宿敌)"></div>
                </div>
                <div id="form-general-fields">
                  <div class="form-group"><label>姓名</label><input type="text" id="archive-name" required placeholder="姓名"></div>
                  <div class="form-group"><label>备注 (不发给 AI)</label><input type="text" id="archive-remark" placeholder="仅自己可见"></div>
                  <div class="form-group"><label>分组</label><input type="text" id="archive-group" placeholder="如：主角团、反派"></div>
                  <div class="form-group"><label>人设</label><textarea id="archive-persona" rows="3" placeholder="System Prompt 人设底料"></textarea></div>
                </div>
                <div class="form-actions">
                  <button type="button" class="btn btn-outline" id="btn-cancel-form">取消</button>
                  <button type="submit" class="btn btn-primary" id="btn-save-archive">保存</button>
                </div>
              </form>
            </div>
          </div>
        </div>
        <footer class="win-footer archive-tabs">
          <button class="tab-item active" data-tab="character">
            <svg viewBox="0 0 24 24"><path fill="currentColor" d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
            <span>角色</span>
          </button>
          <button class="tab-item" data-tab="user">
            <svg viewBox="0 0 24 24"><path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/></svg>
            <span>用户</span>
          </button>
          <button class="tab-item" data-tab="npc">
            <svg viewBox="0 0 24 24"><path fill="currentColor" d="M12 11.55C9.64 9.35 6.48 8 3 8v11c3.48 0 6.64 1.35 9 3.55 2.36-2.2 5.52-3.55 9-3.55V8c-3.48 0-6.64 1.35-9 3.55zM12 4c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2z"/></svg>
            <span>NPC</span>
          </button>
          <button class="tab-item" data-tab="relation">
            <svg viewBox="0 0 24 24"><path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>
            <span>关系网</span>
          </button>
        </footer>
      </div>

      <!-- === 聊天/社交应用 === -->
      <div id="win-chat" class="app-window">
        <header class="win-header" id="chat-app-main-header">
          <button class="btn-icon" onclick="closeApp('chat')">
            <svg viewBox="0 0 24 24"><path fill="currentColor" d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
          </button>
          <h3 id="chat-main-title">对话</h3>
          <button class="btn-icon" id="btn-new-chat">
            <svg viewBox="0 0 24 24"><path fill="currentColor" d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
          </button>
        </header>

        <!-- 聊天主容器 -->
        <div class="win-body chat-app-body" style="padding:0;">
          
          <!-- 对话页签 -->
          <section id="chat-tab-sessions" class="chat-tab-panel active">
            <div class="session-list" id="session-list-container"></div>
          </section>

          <!-- 朋友圈页签 -->
          <section id="chat-tab-moments" class="chat-tab-panel">
            <div class="moments-feed">
              <div class="moment-cover">
                <div class="moment-user-info">
                  <span id="moment-user-name">未选择我的人设</span>
                  <img id="moment-user-avatar" class="avatar-sm" src="data:image/svg+xml;utf8,<svg viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg'><circle cx='12' cy='12' r='12' fill='%23e8f0fe'/></svg>" />
                </div>
              </div>
              <div class="moment-list">
                <p style="text-align: center; color: var(--text-secondary); margin-top:40px; font-size:13px;">暂无朋友圈动态</p>
              </div>
            </div>
          </section>

          <!-- 我的页签 -->
          <section id="chat-tab-me" class="chat-tab-panel">
            <div class="me-header">
              <div class="me-profile-selector">
                <label>切换我的人设(全局跟随)</label>
                <select id="me-persona-select"><option value="">-- 请选择我的人设 --</option></select>
              </div>
            </div>
            <div class="me-menu">
              <div class="menu-item" onclick="openMeSub('stickers')">
                <span>我的表情包</span>
                <svg viewBox="0 0 24 24" class="chevron"><path fill="currentColor" d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/></svg>
              </div>
              <div class="menu-item" onclick="openMeSub('collection')">
                <span>收藏室</span>
                <svg viewBox="0 0 24 24" class="chevron"><path fill="currentColor" d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/></svg>
              </div>
              <div class="menu-item" onclick="openMeSub('wallet')">
                <span>钱包</span>
                <svg viewBox="0 0 24 24" class="chevron"><path fill="currentColor" d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/></svg>
              </div>
            </div>
          </section>
        </div>

        <!-- 聊天主窗口下部底栏 -->
        <footer class="win-footer chat-tabs">
          <button class="tab-item active" data-chat-tab="sessions">
            <svg viewBox="0 0 24 24"><path fill="currentColor" d="M20 2H4c-1.1 0-1.99.9-1.99 2L2 22l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM6 9h12v2H6V9zm8 5H6v-2h8v2zm4-6H6V6h12v2z"/></svg>
            <span>对话</span>
          </button>
          <button class="tab-item" data-chat-tab="moments">
            <svg viewBox="0 0 24 24"><path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.53c-.26-.81-1-1.4-1.9-1.4h-1v-3c0-.55-.45-1-1-1h-6v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.4z"/></svg>
            <span>朋友圈</span>
          </button>
          <button class="tab-item" data-chat-tab="me">
            <svg viewBox="0 0 24 24"><path fill="currentColor" d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
            <span>我的</span>
          </button>
        </footer>

        <!-- === 微信选人单聊弹窗 === -->
        <div id="new-chat-overlay" class="modal-overlay">
          <div class="modal">
            <header class="modal-header">
              <h4>发起单聊 - 选择角色</h4>
              <button class="btn-icon" id="btn-close-new-chat">
                <svg viewBox="0 0 24 24"><path fill="currentColor" d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
              </button>
            </header>
            <div class="win-body" id="new-chat-list">
              <!-- 角色和NPC列表选择 -->
            </div>
          </div>
        </div>

        <!-- === 我的二级子页面（重构至顶级，解决二级页滑块横向溢出泄漏问题） === -->
        <div id="me-sub-panel" class="me-sub-overlay">
          <div class="me-sub-container">
            <header class="win-header">
              <button class="btn-icon" onclick="closeMeSub()">
                <svg viewBox="0 0 24 24"><path fill="currentColor" d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
              </button>
              <h3 id="me-sub-title">子页面</h3>
              <button class="btn-icon" id="btn-me-sub-add" style="display:none;">
                <svg viewBox="0 0 24 24"><path fill="currentColor" d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
              </button>
            </header>
            <div class="win-body" id="me-sub-body"></div>
          </div>
        </div>

        <!-- === 微信仿真对话层（重构至顶级） === -->
        <div id="chat-dialog-panel" class="chat-dialog-overlay">
          <header class="win-header">
            <button class="btn-icon" onclick="closeChatDialog()">
              <svg viewBox="0 0 24 24"><path fill="currentColor" d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
            </button>
            <h3 id="dialog-header-title">对话名</h3>
            <button class="btn-icon" id="btn-dialog-details">
              <svg viewBox="0 0 24 24"><path fill="currentColor" d="M6 10c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm12 0c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm-6 0c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/></svg>
            </button>
          </header>
          
          <!-- 消息流展示区 -->
          <div class="dialog-messages" id="dialog-messages-container"></div>
          
          <!-- 微信输入底栏 -->
          <div class="dialog-input-container">
            <div class="input-main-row" id="normal-input-row">
              <button class="btn-icon" id="btn-chat-expand-toggle">
                <svg viewBox="0 0 24 24"><path fill="currentColor" d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
              </button>
              <textarea id="dialog-input-text" rows="1" placeholder="发送消息..."></textarea>
              
              <button class="chat-send-btn" id="btn-dialog-send" title="发送消息">
                <svg viewBox="0 0 24 24"><path fill="currentColor" d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
              </button>
              <button class="chat-send-btn reply" id="btn-dialog-reply" title="生成回复">
                <svg viewBox="0 0 24 24"><path fill="currentColor" d="M19 9l1.25-2.75L23 5l-2.75-1.25L19 1 17.75 3.75 15 5l2.75 1.25L19 9zm-7.5.5L9 4 6.5 9.5 1 12l5.5 2.5L9 20l2.5-5.5 5.5-2.5-5.5-2.5zm7.5 5l-1.25 2.75L15 19l2.75 1.25L19 23l1.25-2.75L23 19l-2.75-1.25L19 14.5z"/></svg>
              </button>
            </div>

            <!-- 多选状态下的底部动作控制条 -->
            <div class="multi-select-action-bar" id="multi-select-bar" style="display: none;">
              <button id="btn-multi-delete" class="btn btn-danger-outline" style="flex:1;">删除选中 (<span id="selected-count">0</span>)</button>
              <button id="btn-multi-cancel" class="btn" style="flex:1;">退出多选</button>
            </div>
            
            <!-- 拓展面板 -->
            <div id="chat-expand-panel" class="expand-panel">
              <div class="expand-grid">
                <div class="expand-item" id="btn-chat-sticker">
                  <div class="expand-icon-wrapper"><svg viewBox="0 0 24 24"><path fill="currentColor" d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"/></svg></div>
                  <span>表情包</span>
                </div>
                <div class="expand-item" id="btn-chat-photo">
                  <div class="expand-icon-wrapper"><svg viewBox="0 0 24 24"><path fill="currentColor" d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 5H5l3.5-4.5z"/></svg></div>
                  <span>图片</span>
                  <input type="file" id="chat-photo-file" accept="image/*" style="display:none;">
                </div>
                <div class="expand-item">
                  <div class="expand-icon-wrapper"><svg viewBox="0 0 24 24"><path fill="currentColor" d="M12 14c1.66 0 2.99-1.34 2.99-3L15 5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3zm5.3-3c0 3-2.54 5.1-5.3 5.1S6.7 14 6.7 11H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c3.28-.48 6-3.3 6-6.72h-1.7z"/></svg></div>
                  <span>语音</span>
                </div>
                <div class="expand-item">
                  <div class="expand-icon-wrapper"><svg viewBox="0 0 24 24"><path fill="currentColor" d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg></div>
                  <span>线下</span>
                </div>
                <div class="expand-item">
                  <div class="expand-icon-wrapper"><svg viewBox="0 0 24 24"><path fill="currentColor" d="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0-2-.9-2-2V4c0-1.1-.9-2-2-2zm0 14H8V4h12v12z"/></svg></div>
                  <span>记忆</span>
                </div>
                <div class="expand-item">
                  <div class="expand-icon-wrapper"><svg viewBox="0 0 24 24"><path fill="currentColor" d="M17 1H7c-1.1 0-2 .9-2 2v18c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V3c0-1.1-.9-2-2-2zm0 18H7V5h10v14z"/></svg></div>
                  <span>查手机</span>
                </div>
                <div class="expand-item">
                  <div class="expand-icon-wrapper"><svg viewBox="0 0 24 24"><path fill="currentColor" d="M14 17H4v2h10v-2zm6-8H4v2h16V9zM4 15h16v-2H4v2zM4 5v2h16V5H4z"/></svg></div>
                  <span>总结</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- 聊天专属详情页面（重构至顶级） -->
        <div id="chat-details-panel" class="chat-details-overlay">
          <header class="win-header">
            <button class="btn-icon" onclick="closeChatDetails()">
              <svg viewBox="0 0 24 24"><path fill="currentColor" d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
            </button>
            <h3>单聊专属设置</h3>
            <div style="width:40px;"></div>
          </header>
          <div class="win-body">
            <div class="form-group">
              <label>自定义对方 (Char) 姓名</label>
              <input type="text" id="details-char-name">
            </div>
            <div class="form-group">
              <label>自定义对方 (Char) 头像 URL / Base64</label>
              <input type="text" id="details-char-avatar" placeholder="例如: https://example.com/a.png">
            </div>
            <div class="form-group">
              <label>自定义对方人设 (AI 提示词)</label>
              <textarea id="details-char-persona" rows="3" placeholder="自定义对方角色的 System Prompt"></textarea>
            </div>
            <div class="form-group">
              <label>自定义我方 (User) 姓名</label>
              <input type="text" id="details-user-name">
            </div>
            <div class="form-group">
              <label>自定义我方 (User) 头像 URL / Base64</label>
              <input type="text" id="details-user-avatar" placeholder="例如: https://example.com/b.png">
            </div>
            <div class="form-group">
              <label>自定义我方人设 (对话专属背景)</label>
              <textarea id="details-user-persona" rows="3" placeholder="自定义我的角色的 System Prompt 背景"></textarea>
            </div>
            <div class="form-group" style="display:none;">
              <label>自动总结触发阈值 (条数)</label>
              <input type="number" id="details-auto-summary" value="50">
            </div>
            <div class="form-actions" style="margin-top: 24px;">
              <button id="btn-save-details" class="btn btn-primary" style="width:100%;">保存当前会话配置</button>
            </div>
          </div>
        </div>

        <!-- === 双击气泡呼出的工具菜单栏 === -->
        <div id="bubble-context-menu" class="bubble-menu-overlay" style="display: none;">
          <div class="bubble-menu-content">
            <button id="btn-menu-edit">编辑消息</button>
            <button id="btn-menu-reroll">回溯重回 (Reroll)</button>
            <button id="btn-menu-favorite">收藏消息</button>
            <button id="btn-menu-multi">多选消息</button>
            <button id="btn-menu-cancel" class="cancel-btn">取消</button>
          </div>
        </div>

      </div> <!-- 聊天应用结束 -->

    </div>

    <!-- 底部 Dock 栏 -->
    <footer id="dock">
      <div class="dock-container" id="dock-grid"></div>
    </footer>
  </div>

  <script src="db.js"></script>
  <script src="app_desktop.js"></script>
  <script src="app_settings.js"></script>
  <script src="app_archive.js"></script>
  <script src="app_chat.js"></script>
</body>
</html>